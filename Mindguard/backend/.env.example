# =============================================================
#  MindGuard Backend — Environment Configuration
#  Copy this file to .env and fill in your actual values
#  cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# Django Core
# -------------------------------------------------------------
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# -------------------------------------------------------------
# Azure OpenAI (GPT) — for AI-powered daily wellness stories
# Get credentials from: https://portal.azure.com
# -------------------------------------------------------------
endpoint=https://your-resource-name.openai.azure.com/
model_name=gpt-4
deployment=your-deployment-name
subscription_key=your-azure-openai-api-key
api_version=2024-02-01

# -------------------------------------------------------------
# Database (default: SQLite for development)
# For production, switch to PostgreSQL
# -------------------------------------------------------------
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=mindguard_db
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# -------------------------------------------------------------
# JWT Authentication
# -------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=3000
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1

# -------------------------------------------------------------
# Google OAuth2 (via django-allauth)
# Get credentials from: https://console.cloud.google.com
# -------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -------------------------------------------------------------
# Media & File Storage
# -------------------------------------------------------------
MEDIA_ROOT=media/
MEDIA_URL=/media/

# -------------------------------------------------------------
# ngrok (for mobile device testing)
# Run: ngrok http 8000
# Then update this with your ngrok URL
# -------------------------------------------------------------
NGROK_URL=https://your-ngrok-url.ngrok-free.app

# -------------------------------------------------------------
# Email (optional — set to console for development)
# -------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
